{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "timeseries",
      "title": "Latencia de Reserva (p95)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(reserve_duration_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "Stock Actual SKU-001",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "inventory_stock_level{sku=\"SKU-001\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 50
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Overselling Intentado",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "expr": "overselling_attempts_total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 1, "color": "red"}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "piechart",
      "title": "Reservas Exitosas vs Rechazadas",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum(increase(reserve_attempts_total{result=\"success\"}[10m]))",
          "legendFormat": "Exitosas",
          "refId": "A"
        },
        {
          "expr": "sum(increase(reserve_attempts_total{result=~\"insufficient_stock|locked|redis_error\"}[10m]))",
          "legendFormat": "Rechazadas",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Usuarios Simultaneos (Requests in-flight)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "reserve_inflight_requests",
          "refId": "A"
        }
      ]
    }
  ],
